@page
@model soft20181_starter.Pages.Admin.Users.CreateModel
@{
    ViewData["Title"] = "Create New User - EventScape";
    Layout = "_Layout";
}

<div class="main-container my-5">
    <div class="featured-events-header">
        <h2 class="featured-title">
            @if (Model.IsSuperAdmin)
            {
                <text>Create New User (SuperAdmin)</text>
            }
            else
            {
                <text>Create Standard User (Admin)</text>
            }
        </h2>
    </div>
    
    <div class="row mb-4">
        <div class="col text-center">
            <div class="admin-navigation-links">
                <a href="/Admin" class="admin-nav-link">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/Admin/Users" class="admin-nav-link">
                    <i class="fas fa-users"></i> All Users
                </a>
            </div>
        </div>
    </div>

    @if (!Model.IsSuperAdmin)
    {
        <div class="alert alert-info text-center mb-4">
            <i class="fas fa-info-circle"></i>
            <strong>Admin Access:</strong> You can only create standard users. Admin roles can only be assigned by SuperAdmin.
        </div>
    }

    <div class="user-form-container">
        <div class="section-header">
            <h3 id="txt">User Information</h3>
        </div>
        
        <div class="admin-form-wrapper">
            <form method="post" class="admin-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger admin-validation-summary"></div>
                
                <div class="admin-form-section">
                    <h3 class="admin-form-section-title">Basic Information</h3>
                    
                    <div class="form-group-row">
                        <div class="form-group">
                            <label asp-for="UserViewModel.Name">First Name</label>
                            <input asp-for="UserViewModel.Name" class="form-control" placeholder="Enter first name" required 
                                   data-val="true" data-val-required="First name is required" data-val-length-max="50" />
                            <span asp-validation-for="UserViewModel.Name" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="UserViewModel.Surname">Last Name</label>
                            <input asp-for="UserViewModel.Surname" class="form-control" placeholder="Enter last name" required 
                                   data-val="true" data-val-required="Last name is required" data-val-length-max="50" />
                            <span asp-validation-for="UserViewModel.Surname" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="form-group-row">
                        <div class="form-group">
                            <label asp-for="UserViewModel.Email">Email</label>
                            <input asp-for="UserViewModel.Email" class="form-control" placeholder="Enter email address" type="email" required 
                                   data-val="true" data-val-required="Email is required" data-val-email="Please enter a valid email address" />
                            <span asp-validation-for="UserViewModel.Email" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="UserViewModel.PhoneNumber">Phone Number (Optional)</label>
                            <input asp-for="UserViewModel.PhoneNumber" class="form-control" placeholder="Enter phone number" 
                                   data-val-length-max="20" />
                            <span asp-validation-for="UserViewModel.PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                <div class="admin-form-section">
                    <h3 class="admin-form-section-title">Security</h3>
                    
                    <div class="form-group-row">
                        <div class="form-group">
                            <label asp-for="UserViewModel.Password">Password</label>
                            <input asp-for="UserViewModel.Password" class="form-control" type="password" placeholder="Enter password" required 
                                   data-val="true" data-val-required="Password is required" data-val-length-min="6" />
                            <span asp-validation-for="UserViewModel.Password" class="text-danger"></span>
                            <div class="form-hint">
                                <i class="fas fa-info-circle"></i>
                                Password must be at least 6 characters long.
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="UserViewModel.ConfirmPassword">Confirm Password</label>
                            <input asp-for="UserViewModel.ConfirmPassword" class="form-control" type="password" placeholder="Confirm password" required 
                                   data-val="true" data-val-required="Please confirm your password" />
                            <span asp-validation-for="UserViewModel.ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                    
                    @if (Model.IsSuperAdmin)
                    {
                        <div class="form-group-row">
                            <div class="form-group">
                                <label asp-for="UserViewModel.Role">Role</label>
                                <select asp-for="UserViewModel.Role" class="form-control" required>
                                    <option value="">-- Select Role --</option>
                                    @foreach (var role in Model.AvailableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <span asp-validation-for="UserViewModel.Role" class="text-danger"></span>
                                <div class="form-hint">
                                    <i class="fas fa-info-circle"></i>
                                    SuperAdmin can create both Admin and User roles.
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="form-group-row">
                            <div class="form-group">
                                <label>Role</label>
                                <input type="text" class="form-control" value="User" readonly />
                                <div class="form-hint">
                                    <i class="fas fa-info-circle"></i>
                                    Admin users can only create standard users.
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                <div class="admin-form-actions">
                    <a asp-page="Index" class="admin-cancel-btn">
                        <i class="fas fa-times-circle"></i> Cancel
                    </a>
                    <button type="submit" id="button2" class="admin-submit-btn">
                        <i class="fas fa-plus-circle"></i> 
                        @if (Model.IsSuperAdmin)
                        {
                            <text>Create User</text>
                        }
                        else
                        {
                            <text>Create Standard User</text>
                        }
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="footer-spacer"></div>

@section Styles {
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>
        /* Main container styling */
        .main-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            background-color: transparent;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }
        
        /* Added footer spacer */
        .footer-spacer {
            height: 100px;
            width: 100%;
            clear: both;
        }
        
        /* Featured title styling from EventDetail.cshtml */
        .featured-title {
            display: inline-block;
            background-color: #522B5B;
            color: white;
            padding: 15px 30px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 28px;
            margin: 20px auto;
            text-align: center;
        }
        
        .featured-events-header {
            margin-top: 10px;
            text-align: center;
            margin-left: 0;
        }
        
        /* Navigation links */
        .admin-navigation-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin: 15px 0;
        }
        
        .admin-nav-link {
            display: inline-block;
            background-color: #854F6C;
            color: white;
            padding: 12px 25px;
            border-radius: 4px;
            text-decoration: none;
            font-weight: bold;
            transition: background-color 0.3s;
        }
        
        .admin-nav-link:hover {
            background-color: #522B5B;
            color: white;
            text-decoration: none;
        }
        
        /* Alert styling */
        .alert-info {
            background-color: #d1ecf1;
            border-color: #bee5eb;
            color: #0c5460;
            padding: 15px;
            border-radius: 4px;
            border: 1px solid transparent;
        }
        
        .alert-info i {
            margin-right: 8px;
        }
        
        /* Form styling */
        .user-form-container {
            background-color: white;
            border-radius: 10px;
            padding: 30px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-top: 20px;
        }
        
        .section-header h3 {
            color: #522B5B;
            font-size: 24px;
            margin-bottom: 20px;
            text-align: center;
            border-bottom: 2px solid #522B5B;
            padding-bottom: 10px;
        }
        
        .admin-form-wrapper {
            max-width: 800px;
            margin: 0 auto;
        }
        
        .admin-form-section {
            margin-bottom: 30px;
            padding: 20px;
            background-color: #f8f9fa;
            border-radius: 8px;
            border-left: 4px solid #522B5B;
        }
        
        .admin-form-section-title {
            color: #522B5B;
            font-size: 18px;
            margin-bottom: 20px;
            font-weight: bold;
        }
        
        .form-group-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .form-group {
            display: flex;
            flex-direction: column;
        }
        
        .form-group label {
            font-weight: bold;
            color: #522B5B;
            margin-bottom: 8px;
        }
        
        .form-control {
            padding: 12px;
            border: 2px solid #e9ecef;
            border-radius: 6px;
            font-size: 16px;
            transition: border-color 0.3s;
        }
        
        .form-control:focus {
            border-color: #522B5B;
            outline: none;
            box-shadow: 0 0 0 3px rgba(82, 43, 91, 0.1);
        }
        
        .form-control[readonly] {
            background-color: #f8f9fa;
            color: #6c757d;
        }
        
        .text-danger {
            color: #dc3545;
            font-size: 14px;
            margin-top: 5px;
        }
        
        .form-hint {
            color: #6c757d;
            font-size: 14px;
            margin-top: 5px;
        }
        
        .form-hint i {
            margin-right: 5px;
        }
        
        .admin-form-actions {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e9ecef;
        }
        
        .admin-cancel-btn {
            background-color: #6c757d;
            color: white;
            padding: 12px 25px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
            transition: background-color 0.3s;
        }
        
        .admin-cancel-btn:hover {
            background-color: #5a6268;
            color: white;
            text-decoration: none;
        }
        
        .admin-submit-btn {
            background-color: #522B5B;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        
        .admin-submit-btn:hover {
            background-color: #854F6C;
        }
        
        .admin-validation-summary {
            margin-bottom: 20px;
        }
        
        /* Responsive design */
        @@media (max-width: 768px) {
            .form-group-row {
                grid-template-columns: 1fr;
            }
            
            .admin-form-actions {
                flex-direction: column;
                align-items: center;
            }
            
            .admin-nav-link {
                padding: 10px 20px;
                font-size: 14px;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
} 